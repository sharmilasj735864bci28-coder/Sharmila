def print_formatted(number):
    # Calculate the width based on the binary representation of the max number
    width = len(bin(number)[2:])
    
    for i in range(1, number + 1):
        # Format each number into its respective base
        dec = str(i)
        octal = oct(i)[2:]
        hex_val = hex(i)[2:].upper()
        binary = bin(i)[2:]
        
        # Print each value right-aligned to the calculated width
        print(f"{dec.rjust(width)} {octal.rjust(width)} {hex_val.rjust(width)} {binary.rjust(width)}")
