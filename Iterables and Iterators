from itertools import combinations
N = int(input())
letters = input().split()
K = int(input())
combos = list(combinations(range(N), K))
a_indices = [i for i, char in enumerate(letters) if char == 'a']
count = 0
for c in combos:
    if any(index in a_indices for index in c):
        count += 1
print(f"{count / len(combos):.4f}")
